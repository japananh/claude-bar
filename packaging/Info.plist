    <!-- Sparkle 2 auto-update. Public key embedded, private key in the
         maintainer's macOS Keychain (generated by `bin/generate_keys`).
         SUEnableAutomaticChecks is FALSE because there is no public
         release pipeline yet — leaving it true would surface daily
         "update failed" dialogs to users since appcast.xml is empty.
         Flip back to true once the first signed release is up at
         SUFeedURL. The manual "Check for updates…" button in AboutTab
         keeps working either way (UpdateController guards an empty
         feed). -->
    <key>SUFeedURL</key>
    <string>https://ncthanhngo.github.io/claude-bar/appcast.xml</string>
    <key>SUPublicEDKey</key>
