    <!-- Sparkle 2 auto-update. SUPublicEDKey is a TODO placeholder — replace
         with the base64 EdDSA public key printed by `bin/generate_keys` from
         Sparkle.xcframework before shipping a release.
         SUEnableAutomaticChecks is FALSE until a real key is in place; with
         the placeholder, Sparkle would reject every download and surface a
         daily user-visible error dialog. Flip to true after rotating the key
         and pushing a signed appcast. The user can still invoke the manual
         "Check for updates…" button at any time — UpdateController guards
         it against the placeholder. -->
    <key>SUFeedURL</key>
    <string>https://ncthanhngo.github.io/claude-bar/appcast.xml</string>
    <key>SUPublicEDKey</key>
    <string>REPLACE_WITH_BASE64_ED25519_PUBLIC_KEY</string>
    <key>SUEnableAutomaticChecks</key>
    <false/>
    <key>SUScheduledCheckInterval</key>
    <integer>86400</integer>
