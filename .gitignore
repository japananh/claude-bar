# IDE
.vscode/
.idea/
*.swp

# Sparkle EdDSA signing key — must never reach Git. Pattern catches both
# the canonical name and accidental copies. The real backup lives in
# ~/sparkle-private.key (outside the repo) and ideally also in a password
# manager / encrypted offline storage.
sparkle-private.key
*.sparkle-key
*-sparkle-private.key

# Local planning & notes (not for remote)
plans/
TECHNICAL-NOTES.md
NOTES.local.md
# Keep .claude/commands/ in git so /release etc. travel with the repo.
# Ignore everything else under .claude/ that's local-only state.
.claude/agent-memory/
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/*.log
CLAUDE.md
daily-briefing-preview.html
